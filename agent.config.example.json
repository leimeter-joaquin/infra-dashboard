{
  "_comment": "Copy this file to agent.config.json and replace REPLACE_ME_WITH_A_STRONG_SECRET with a real secret. Never commit agent.config.json.",
  "token": "REPLACE_ME_WITH_A_STRONG_SECRET",
  "allowedOrigins": ["http://localhost:3000"],
  "actions": [
    {
      "id": "open-editor",
      "description": "Open project in VS Code",
      "cmd": "code",
      "args": ["/c/workspace/your-project"]
    },
    {
      "id": "restart-wrangler",
      "description": "Kill running wrangler process (restart manually after)",
      "cmd": "pkill",
      "args": ["-f", "wrangler"]
    },
    {
      "id": "start-dev-server",
      "description": "Start a dev server in the background",
      "cmd": "npm",
      "args": ["run", "dev"],
      "cwd": "/path/to/your-project",
      "detached": true
    },
    {
      "id": "test-detached",
      "description": "Test detached sleep action",
      "cmd": "sleep",
      "args": ["100"],
      "detached": true
    }
  ]
}
